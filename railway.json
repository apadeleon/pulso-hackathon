{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install && cd demo-app && npx vite build"
  },
  "deploy": {
    "startCommand": "cd demo-app && npx vite preview --host 0.0.0.0 --port $PORT",
    "healthcheckPath": "/"
  }
}
